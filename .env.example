# ── Canonical site URL ──
# Drives metadataBase + all OG/Twitter share tags (src/lib/config.ts).
# Locally leave empty (defaults to the prod URL). In Vercel, set this on the
# waitlist project to its live domain, e.g. https://waitlist.benderai.app
NEXT_PUBLIC_APP_URL=

# ── Clerk (use the SAME keys as the main Bender app so buyers become
#    real accounts the lifetime entitlement can attach to) ──
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ── Polar checkout for the $5 waitlist deal ──
# Create a $5 one-time "Waitlist" product in Polar, make a checkout link,
# paste it here. /claim appends clerk_user_id + success_url automatically.
# Easiest path: run `node scripts/setup-polar.mjs` — it creates the product +
# link and fills in this var and POLAR_WAITLIST_PRODUCT_ID below.
NEXT_PUBLIC_POLAR_WAITLIST_CHECKOUT_URL=

# ── Live "joined" counter (optional) ──
# With both set, /api/spots counts real paid orders for the waitlist product
# from the Polar API (cached 60s). Otherwise the manual count in
# src/lib/config.ts is shown.
POLAR_ACCESS_TOKEN=
POLAR_WAITLIST_PRODUCT_ID=
# "sandbox" while testing, "production" when live.
POLAR_SERVER=sandbox

# ── Duplicate-purchase guard (optional but recommended) ──
# Before sending a signed-in user to checkout, /claim asks the main app whether
# they have ALREADY joined the waitlist, and if so skips checkout (so nobody
# pays the $5 twice). Point this at a main-app endpoint that accepts
# ?clerk_user_id=… and returns { joined: true } (also accepts
# { waitlistMember: true }). Optional bearer token for that endpoint. If unset,
# the guard is skipped (fails open).
ENTITLEMENT_CHECK_URL=
ENTITLEMENT_CHECK_SECRET=
