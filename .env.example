# ── Canonical site URL ──
# Drives metadataBase + all OG/Twitter share tags (src/lib/config.ts).
# Locally leave empty (defaults to the prod URL). In Vercel, set this on the
# waitlist project to its live domain, e.g. https://waitlist.benderai.app
NEXT_PUBLIC_APP_URL=

# ── Clerk (use the SAME keys as the main Bender app so buyers become
#    real accounts the lifetime entitlement can attach to) ──
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ── Polar checkout for the $49 lifetime deal ──
# Create a $49 one-time "Lifetime" product in Polar, make a checkout link,
# paste it here. /claim appends clerk_user_id + success_url automatically.
NEXT_PUBLIC_POLAR_LIFETIME_CHECKOUT_URL=

# ── Live spot counter (optional) ──
# With both set, /api/spots counts real paid orders for the lifetime product
# from the Polar API (cached 60s). Otherwise the manual count in
# src/lib/config.ts is shown.
POLAR_ACCESS_TOKEN=
POLAR_LIFETIME_PRODUCT_ID=
# "sandbox" while testing, "production" when live.
POLAR_SERVER=sandbox

# ── Free "notify me at launch" list (Resend) ──
# Signups become contacts in a Resend audience; the launch email is sent
# later as a broadcast to that audience.
# 1. resend.com → API Keys → create a key (Sending access is enough).
# 2. resend.com → Audiences → create one, copy its ID.
# Without both set, dev accepts signups locally so the form is testable.
RESEND_API_KEY=
RESEND_AUDIENCE_ID=
